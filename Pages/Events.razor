@page "/event-details/{sportKey}/{id}"

@inject ITheOddsService TheOddsService

<div class="container my-4">
    @if (analyzedEvent == null && !isLoading)
    {
        <div class="alert alert-danger mt-4">
            Event not found or failed to load
        </div>
    }
    else if (isLoading)
    {
        <div class="text-center my-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-3">Loading event details...</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white text-center">
                <h1 class="mb-0">@analyzedEvent.MatchDisplay</h1>
                <small>@(analyzedEvent.FormattedDate ?? "N/A")</small>
            </div>

            <div class="card-body">
                <div class="row mb-4">
                    <div class="col-md-6">
                        <strong>Sport:</strong> @analyzedEvent.SportTitle
                    </div>
                    <div class="col-md-6 text-end">
                        <strong>@analyzedEvent.FlatBookmakers.Count</strong> bookmakers
                    </div>
                </div>

                @if (!analyzedEvent.FlatBookmakers.Any())
                {
                    <div class="alert alert-info">No odds available from bookmakers at this time.</div>
                }
                else
                {
                    <!-- Best Odds -->
                    <h5 class="mt-5 mb-2">Best Odds Available</h5>
                    <p class="text-muted small mb-3">
                        The lowest (most favourable) odds currently offered for each outcome across all bookmakers.
                        These are the best prices available right now — always check these before placing a bet.
                        Calculated by finding the minimum odds value per outcome among all bookmakers with valid prices.
                    </p>

                    <div class="row mb-4 text-center">
                        <div class="col-md-4">
                            <div class="p-3 border rounded bg-light">
                                <h6>Best Home</h6>
                                <p class="fs-4 fw-bold text-success mb-0">
                                    @(analyzedEvent.BestOdds.Home.Odds?.ToString("F2") ?? "-")
                                </p>
                                <small>@analyzedEvent.BestOdds.Home.Bookmaker</small>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 border rounded bg-light">
                                <h6>Best Draw</h6>
                                <p class="fs-4 fw-bold text-success mb-0">
                                    @(analyzedEvent.BestOdds.Draw.Odds?.ToString("F2") ?? "-")
                                </p>
                                <small>@analyzedEvent.BestOdds.Draw.Bookmaker</small>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 border rounded bg-light">
                                <h6>Best Away</h6>
                                <p class="fs-4 fw-bold text-success mb-0">
                                    @(analyzedEvent.BestOdds.Away.Odds?.ToString("F2") ?? "-")
                                </p>
                                <small>@analyzedEvent.BestOdds.Away.Bookmaker</small>
                            </div>
                        </div>
                    </div>

                    <!-- Margin -->
                    <h5 class="mt-5 mb-2">Average Bookmaker Margin (Overround)</h5>
                    <p class="text-muted small mb-3">
                        The average built-in profit margin across all bookmakers.
                        Lower margin means a more efficient/fairer market for bettors. Typical range 5–12%.
                        Calculated as: for each bookmaker ( 1/home + 1/draw + 1/away ) - 1 × 100%, then averaged.
                    </p>

                    <div class="alert alert-secondary mb-4 text-center">
                        <strong>@analyzedEvent.Margin.Percent.ToString("F2")%</strong>
                        <small>(@analyzedEvent.Margin.Description)</small>
                    </div>

                    <!-- Consensus -->
                    <h5 class="mt-5 mb-2">Market Consensus (Average Odds)</h5>
                    <p class="text-muted small mb-3">
                        The "crowd wisdom" average odds from all bookmakers — represents the market's collective view of the probabilities.
                        Calculated as the simple arithmetic mean of all valid odds for each outcome.
                    </p>

                    <div class="row mb-4 text-center">
                        <div class="col">
                            <div class="p-3 border rounded bg-light">
                                <strong>Market Average:</strong>
                                Home @analyzedEvent.Consensus.Home.ToString("F2") |
                                Draw @analyzedEvent.Consensus.Draw.ToString("F2") |
                                Away @analyzedEvent.Consensus.Away.ToString("F2")
                            </div>
                        </div>
                    </div>

                    <!-- Value Indicator -->
                    <h5 class="mt-5 mb-2">Potential Value Bets</h5>
                    <p class="text-muted small mb-3">
                        Bookmakers offering odds that are significantly better (lower price) than the market average.
                        These could be mispriced opportunities if you believe the market consensus is correct.
                        Calculated as: bookmaker's odds &lt; 95% of market average (5% threshold).
                    </p>

                    @if (analyzedEvent.ValueBets.HasAny)
                    {
                        <div class="alert alert-success mt-3 text-center">
                            <strong>Value Bets Detected:</strong><br />
                            @if (analyzedEvent.ValueBets.Home.Any())
                            {
                                <div>Home Win at: @string.Join(", ", analyzedEvent.ValueBets.Home)</div>
                            }
                            @if (analyzedEvent.ValueBets.Draw.Any())
                            {
                                <div>Draw at: @string.Join(", ", analyzedEvent.ValueBets.Draw)</div>
                            }
                            @if (analyzedEvent.ValueBets.Away.Any())
                            {
                                <div>Away Win at: @string.Join(", ", analyzedEvent.ValueBets.Away)</div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-light mt-3 text-muted">
                            No obvious value bets detected (odds close to market average).
                        </div>
                    }

                    <!-- Full odds table -->
                    <h5 class="mt-5 mb-3 text-center">
                        Full Odds from All Bookmakers
                    </h5>
                    <div class="table-responsive">
                        <table class="table table-striped table-hover table-sm">
                            <thead>
                                <tr>
                                    <th>Bookmaker</th>
                                    <th>Home Win</th>
                                    <th>Draw</th>
                                    <th>Away Win</th>
                                    <th>Last Update</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var bm in analyzedEvent.FlatBookmakers.OrderBy(b => b.BookmakerName))
                                {
                                    <tr>
                                        <td>@bm.BookmakerName</td>
                                        <td>@(bm.HomeWin?.ToString("F2") ?? "-")</td>
                                        <td>@(bm.Draw?.ToString("F2") ?? "-")</td>
                                        <td>@(bm.AwayWin?.ToString("F2") ?? "-")</td>
                                        <td>@(bm.LastUpdate?.ToString("dd MMM HH:mm") ?? "N/A")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public string? sportKey { get; set; }

    [Parameter]
    public string? id { get; set; }

    private AnalyzedEvent? analyzedEvent { get; set; }
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;

        try
        {
            if (!string.IsNullOrEmpty(sportKey) && !string.IsNullOrEmpty(id))
            {
                analyzedEvent = await TheOddsService.GetAnalyzedEventAsync(sportKey, id);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);
        }
        finally
        {
            isLoading = false;
        }
    }
}
