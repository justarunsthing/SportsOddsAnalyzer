@page "/sports"

@inject TheOddsService TheOddsService

<PageTitle>Sports</PageTitle>

<div class="container-xxl py-3">
    <div class="row mt-3">
        <div class="col">
            <h1>
                In-season sports
            </h1>
            <p class="text-muted">
                Browse all available sports title, view active markets, and explore upcoming events.
            </p>
        </div>
    </div>
    <div class="row g-3">
        <div class="col-12">
            @if (sports == null)
            {
                <div class="d-flex justify-content-center align-items-center">
                    @if (isLoading)
                    {
                        <div class="text-center py-5">
                            <div class="spinner-border text-primary" role="status"></div>
                            <div class="mt-2 text-muted">Loading sports...</div>
                        </div>
                    }
                    else
                    {
                        <h2 class="text-danger">Failed to in-season sports</h2>
                    }
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover table-bordered">
                        <thead class="table-dark">
                            <tr>
                                <th>Title</th>
                                <th>Description</th>
                                <th>Active</th>
                                <th>Outrights</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sport in sports.OrderBy(s => s.Title))
                            {
                                <tr>
                                    <td>@sport.Title</td>
                                    <td>@sport.Description</td>
                                    <td>
                                        @if (sport.Active)
                                        {
                                            <span class="badge bg-success">Yes</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">No</span>
                                        }
                                    </td>
                                    <td>
                                        @if (sport.HasOutrights)
                                        {
                                            <span class="badge bg-primary">Yes</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">No</span>
                                        }
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-primary">
                                            View Events
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private IEnumerable<Sport> sports = [];
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            sports = await TheOddsService.GetInSeasonSportsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);
        }
        finally
        {
            isLoading = false;
        }
    }
}