@page "/sports"

@inject TheOddsService TheOddsService

<PageTitle>Sports</PageTitle>

<div class="container-xxl py-3">
    <div class="row mt-3">
        <div class="col">
            <h1>
                In-season sports
            </h1>
            <p class="text-muted">
                Browse all available sports title, view active markets, and explore upcoming events.
            </p>
        </div>
    </div>
    <div class="row g-3">
        <div class="col-12">
            @if (isLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary"></div>
                    <div class="mt-2 text-muted">Loading in-season sports...</div>
                </div>
            }
            else if (!sports.Any())
            {
                <div class="alert alert-warning text-center">
                    No sports are currently available.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover table-bordered">
                        <thead class="table-dark">
                            <tr>
                                <th>Title</th>
                                <th>Description</th>
                                <th>Active</th>
                                <th>Outrights</th>
                                <th>Actions</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var sport in sports.OrderBy(s => s.Title))
                            {
                                <tr>
                                    <td>@sport.Title</td>
                                    <td>@sport.Description</td>
                                    <td>
                                        <span class="badge @(sport.Active ? "bg-success" : "bg-danger")">
                                            @(sport.Active ? "Yes" : "No")
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge @(sport.HasOutrights ? "bg-primary" : "bg-secondary")">
                                            @(sport.HasOutrights ? "Yes" : "No")
                                        </span>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-primary" @onclick="() => ShowEventsModal(sport.Key)">
                                            View Events
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal -->
@if (showModal && selectedSportKey != null)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Events for @selectedSportTitle</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    @if (modalEvents == null)
                    {
                        <div class="text-center">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    }
                    else if (!modalEvents.Any())
                    {
                        <div class="alert alert-info">No upcoming events found</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th>Match</th>
                                        <th>Date / Time</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var evt in modalEvents.OrderBy(e => e.CommenceTime))
                                    {
                                        <tr>
                                            <td>
                                                @evt.HomeTeam <strong>VS</strong> @evt.AwayTeam
                                            </td>
                                            <td>
                                                @(evt.CommenceTime?.ToString("dd MMM yyyy HH:mm") ?? "N/A")
                                            </td>
                                            <td>
                                                <a href="/event-details/@selectedSportKey/@evt.Id" class="btn btn-sm btn-primary">
                                                    Details
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Backdrop -->
    <div class="modal-backdrop fade show"></div>
}

@code {
    private IEnumerable<Sport> sports = [];
    private bool isLoading = true;

    // Modal state
    private bool showModal = false;
    private string? selectedSportKey;
    private string? selectedSportTitle;
    private IEnumerable<Event> modalEvents = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            sports = await TheOddsService.GetInSeasonSportsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);
        }
        finally
        {
            isLoading = false;
        }
    }

     private async Task ShowEventsModal(string? key)
     {
        if (string.IsNullOrEmpty(key))
        {
            return;
        }

        selectedSportKey = key;
        selectedSportTitle = sports.FirstOrDefault(s => s.Key == key)?.Title;

        try
        {
            modalEvents = await TheOddsService.GetEventsByKeyAsync(key);
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);
            modalEvents = [];
        }

        showModal = true;
     }

    private void CloseModal()
    {
        showModal = false;
        selectedSportKey = null;
        selectedSportTitle = null;
        modalEvents = [];
    }
}