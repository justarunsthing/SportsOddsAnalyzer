@page "/sports"

@inject TheOddsService TheOddsService

<PageTitle>Sports</PageTitle>

<div class="container-xxl py-3">
    <div class="row mt-3">
        <div class="col">
            <h1>
                In-season sports
            </h1>
            <p class="text-muted">
                Browse all available sports title, view active markets, and explore upcoming events.
            </p>
        </div>
    </div>
    <div class="row g-3">
        <div class="col-12">
            @if (isLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary"></div>
                    <div class="mt-2 text-muted">Loading in-season sports...</div>
                </div>
            }
            else if (!sports.Any())
            {
                <div class="alert alert-warning text-center">
                    No sports are currently available.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover table-bordered">
                        <thead class="table-dark">
                            <tr>
                                <th>Title</th>
                                <th>Description</th>
                                <th>Active</th>
                                <th>Outrights</th>
                                <th>Actions</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var sport in sports.OrderBy(s => s.Title))
                            {
                                <tr>
                                    <td>@sport.Title</td>
                                    <td>@sport.Description</td>
                                    <td>
                                        <span class="badge @(sport.Active ? "bg-success" : "bg-danger")">
                                            @(sport.Active ? "Yes" : "No")
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge @(sport.HasOutrights ? "bg-primary" : "bg-secondary")">
                                            @(sport.HasOutrights ? "Yes" : "No")
                                        </span>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-primary">
                                            View Events
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private IEnumerable<Sport> sports = [];
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            sports = await TheOddsService.GetInSeasonSportsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);
        }
        finally
        {
            isLoading = false;
        }
    }
}