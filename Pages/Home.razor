@page "/"

<PageTitle>Home</PageTitle>

<div class="page-style h-100 d-flex justify-content-center">
    <div class="row row-cols-1 row-cols-xl-2 container-xxl h-100">
        <div class="col d-flex flex-column justify-content-xl-center order-last order-xl-first">
            <div class="title">Sports Odds Analyzer</div>
            <div class="sub-title">
                Compare bookmaker odds, uncover market margins, identify value bets,
                and make smarter data-driven betting decisions.
            </div>
            <div class="mt-3">
                <a href="/sports" class="rounded btn btn-primary">
